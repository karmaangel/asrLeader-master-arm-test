FROM ascendai/pytorch:2.1.0-ubuntu22.04

WORKDIR /app

RUN apt-get update && apt-get install -y --no-install-recommends \
    ffmpeg libsndfile1 && rm -rf /var/lib/apt/lists/*

RUN pip install --no-cache-dir "numpy<2" \
    -i https://mirrors.aliyun.com/pypi/simple/ --trusted-host mirrors.aliyun.com

RUN pip install --no-cache-dir torchaudio==2.1.0 \
    --index-url https://download.pytorch.org/whl/cpu

COPY requirements-npu.txt .
RUN TORCH_VER=$(python -c "import torch; print(torch.__version__.split('+')[0])") && \
    echo "torch==${TORCH_VER}" > /tmp/constraints.txt && \
    echo "torchaudio==2.1.0" >> /tmp/constraints.txt && \
    cat /tmp/constraints.txt && \
    pip install --no-cache-dir -r requirements-npu.txt \
        -c /tmp/constraints.txt \
        -i https://mirrors.aliyun.com/pypi/simple/ --trusted-host mirrors.aliyun.com

RUN python -c "import torch; import torch_npu; print('torch:', torch.__version__); print('torch_npu:', torch_npu.__version__); print('npu registered:', 'npu' in dir(torch))"

COPY app/ ./app/

ENV ASCEND_HOME_PATH=/usr/local/Ascend/ascend-toolkit/latest
ENV ASCEND_OPP_PATH=/usr/local/Ascend/ascend-toolkit/latest/opp
ENV ASCEND_AICPU_PATH=/usr/local/Ascend/ascend-toolkit/latest
ENV TOOLCHAIN_HOME=/usr/local/Ascend/ascend-toolkit/latest/toolkit
ENV ASR_DEVICE=npu:0
ENV MODELS_DIR=/models
ENV DATA_DIR=/data
ENV POSTPROCESS_ENABLED=true
ENV POSTPROCESS_PRELOAD=true
ENV POSTPROCESS_DEVICE=npu:0
ENV POSTPROCESS_MODEL=Qwen/Qwen2.5-1.5B-Instruct
ENV POSTPROCESS_MODEL_DIR=/models/Qwen2.5-1.5B-Instruct
ENV POSTPROCESS_WORKERS=1
ENV POSTPROCESS_SYNC_MAX_CHARS=1200
ENV POSTPROCESS_SYNC_TIMEOUT_SECONDS=120
ENV CORRECTION_TASK_WORKERS=1
ENV TRANSFORMERS_OFFLINE=1
ENV MODELSCOPE_OFFLINE=1

WORKDIR /app/app

EXPOSE 8000
ENTRYPOINT []
CMD ["python", "server.py"]
