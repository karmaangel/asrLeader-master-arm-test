FROM funasr-leader-asr:npu-ascend-20260601

WORKDIR /app

COPY app/ ./app/
COPY deploy/ascend-npu/models/ ./models/

ENV ASR_DEVICE=npu:0
ENV MODELS_DIR=/app/models
ENV DATA_DIR=/data
ENV POSTPROCESS_ENABLED=true
ENV POSTPROCESS_PRELOAD=true
ENV POSTPROCESS_DEVICE=npu:0
ENV POSTPROCESS_MODEL=Qwen/Qwen2.5-1.5B-Instruct
ENV POSTPROCESS_MODEL_DIR=/app/models/Qwen2.5-1.5B-Instruct
ENV POSTPROCESS_WORKERS=1
ENV POSTPROCESS_SYNC_MAX_CHARS=1200
ENV POSTPROCESS_SYNC_TIMEOUT_SECONDS=120
ENV CORRECTION_TASK_WORKERS=1
ENV TRANSFORMERS_OFFLINE=1
ENV MODELSCOPE_OFFLINE=1

WORKDIR /app/app
EXPOSE 8000
ENTRYPOINT []
CMD ["python", "server.py"]
